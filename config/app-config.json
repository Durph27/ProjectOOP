{
  "disaster": {
    "name": "Bão Yagi (Bão số 3)",
    "nameEn": "Typhoon Yagi",
    "startDate": "2024-09-01",
    "endDate": "2024-09-30",
    "peakDate": "2024-09-08",
    "region": "Miền Bắc Việt Nam"
  },
  "sentiment": {
    "provider": "python-api",
    "pythonApiUrl": "http://localhost:5000",
    "batchSize": 50,
    "timeout": 30000,
    "positiveId": "POSITIVE",
    "negativeId": "NEGATIVE",
    "neutralId": "NEUTRAL",
    "labels": [
      { "id": "POSITIVE", "nameVi": "Tích cực", "nameEn": "Positive" },
      { "id": "NEGATIVE", "nameVi": "Tiêu cực", "nameEn": "Negative" },
      { "id": "NEUTRAL", "nameVi": "Trung lập", "nameEn": "Neutral" }
    ]
  },
  "collection": {
    "defaultPlatform": "csv",
    "maxPostsPerCollection": 10000,
    "rateLimitMs": 1000,
    "platforms": [
      { "id": "twitter", "displayName": "Twitter/X" },
      { "id": "facebook", "displayName": "Facebook" },
      { "id": "tiktok", "displayName": "TikTok" },
      { "id": "youtube", "displayName": "YouTube" },
      { "id": "csv", "displayName": "CSV Import" },
      { "id": "other", "displayName": "Khác" }
    ]
  },
  "preprocessing": {
    "enabledSteps": [
      "html_cleaner",
      "url_remover",
      "emoji_handler",
      "vietnamese_normalizer",
      "stopword_remover"
    ]
  },
  "storage": {
    "type": "json",
    "rawDataDir": "data/raw",
    "processedDataDir": "data/processed",
    "resultsDir": "data/results"
  },
  "analyzers": {
    "enabled": [
      "sentiment_timeline",
      "damage_classification",
      "relief_satisfaction",
      "relief_sentiment_timeline"
    ]
  }
